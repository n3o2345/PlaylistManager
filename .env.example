# Optional overrides only. This file is not required for normal use.
# Docker Compose will pick up .env automatically if present.

# Override the published image owner/tag when using docker-compose.ghcr.yml.
# GHCR_OWNER=kineticman
# FASTCHANNELSV2_IMAGE_TAG=latest

# Optional public base URL used in admin/feed/M3U/EPG links.
# Useful if you access the UI via localhost but want generated URLs to point to
# a LAN address or reverse proxy hostname instead.
# PUBLIC_BASE_URL=http://192.168.1.50:5523

# Advanced runtime overrides if you need them.
# DATABASE_URL=sqlite:////data/fastchannels.db
# REDIS_URL=redis://localhost:6379/0
