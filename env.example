# Optional overrides only. This file is not required for normal use.
# Docker Compose will pick up .env automatically if present.

# Override the published image owner/tag when using docker-compose.ghcr.yml.
# GHCR_OWNER=kineticman
# FASTCHANNELSV2_IMAGE_TAG=latest

# Optional public base URL used in admin/feed/M3U/EPG links.
# Useful if you access the UI via localhost but want generated URLs to point to
# a LAN address or reverse proxy hostname instead.
# PUBLIC_BASE_URL=http://192.168.1.50:5523

# Advanced runtime overrides if you need them.
# DATABASE_URL=sqlite:////data/playlistmanager.db
# REDIS_URL=redis://localhost:6379/0

# Durable auth storage. Defaults already point at /data/auth, which is on the
# Docker volume, so source logins and Pluto X11 cookies survive rebuilds.
# FASTCHANNELS_AUTH_DIR=/data/auth
# PLUTO_X11_COOKIE_PATH=/data/auth/pluto_x11_cookies.json
# PLUTO_X11_CLIENT_ID_PATH=/data/auth/pluto_x11_client_id

# ---------------------------------------------------------------------------
# Pluto X11 — Hardware transcoding presets
# ---------------------------------------------------------------------------
# Select a named preset to control capture resolution, framerate, and bitrate.
# Individual overrides below take priority over the preset.
#
# Available presets:
#   480p        854x480  @ 30fps  1200k  (low bandwidth)
#   720p        1280x720 @ 30fps  2500k  (default)
#   720p_high   1280x720 @ 60fps  4000k  (smooth 60 fps)
#   1080p       1920x1080@ 30fps  5000k  (HD)
#   1080p_high  1920x1080@ 60fps  8000k  (HD 60 fps)
#   4k_preview  3840x2160@ 30fps 16000k  (GPU encoders only)
#
# PLUTO_X11_PRESET=720p

# Encoder selection — auto-detected if not set (NVENC > VAAPI > libx264).
# Values: nvenc, vaapi, libx264
# PLUTO_X11_ENCODER=nvenc

# Fine-grained overrides (override individual preset values):
# PLUTO_X11_WIDTH=1280
# PLUTO_X11_HEIGHT=720
# PLUTO_X11_FPS=30
# PLUTO_X11_BITRATE=2500k

# NVENC quality preset (p1=fastest … p7=best quality).
# p2=low-latency default, p3=balanced, p4=quality for 1080p+
# PLUTO_X11_NVENC_PRESET=p2

# VAAPI constant QP (lower = better quality, larger file).
# 18=excellent, 22=good, 26=acceptable
# PLUTO_X11_VAAPI_QP=24

# ---------------------------------------------------------------------------
# Pluto X11 — Session pool & resting state
# ---------------------------------------------------------------------------
# Maximum concurrent X11 sessions (active + resting combined).
# Increase to allow more simultaneous viewers; each session uses ~1 CPU core
# and the GPU encoder (if enabled).
# PLUTO_X11_POOL_MAX_SESSIONS=3

# Channel ID to park resting sessions on (the "guide" / home channel).
# Leaving Chromium open on the guide means the browser is pre-warmed and
# ready for the next user — eliminating cold-start delay.
# Find the channel_id from the Pluto API or admin channels page.
# Leave blank to disable resting sessions (classic mode).
# PLUTO_X11_POOL_RESTING_CHANNEL=5a99d1b346ce8906a4693b39

# Full URL for the resting channel (loaded in Chromium while parked).
# Defaults to the Pluto guide landing page (no live stream — just the EPG).
# PLUTO_X11_POOL_RESTING_URL=https://pluto.tv/live-tv

# Idle timeout (seconds) before an ACTIVE session with no readers is evicted.
# Resting sessions are never evicted by idle timeout.
# PLUTO_X11_IDLE_TIMEOUT=30
